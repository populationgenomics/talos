// Nextflow profile for running the full pipeline against committed test fixtures.
//
// Usage:
//   nextflow run main.nf -c nextflow/test.config
//
// Inherits defaults from nextflow.config; overrides only the inputs and the
// fixed-month timestamp so cliprbitration / panelapp lookups resolve to fixture
// names rather than the calendar month.

params {
    // Point every annotation source at the committed fixtures.
    large_files = "test/fixtures/large_files"
    processed_annotations = "test/fixtures/processed_annotations"

    // locations of fixture resources
    mane_json = "${params.processed_annotations}/mane.json"
    ensembl_gff = "${params.large_files}/Homo_sapiens.GRCh38.116.MTtoM.gff3.gz"
    ensembl_bed = "${params.processed_annotations}/GRCh38.bed"
    ensembl_merged_bed = "${params.processed_annotations}/GRCh38_merged.bed"
    alphamissense_tsv = "${params.large_files}/AlphaMissense_hg38.tsv.gz"
    alphamissense_zip = "${params.processed_annotations}/alphamissense.zip"
    mitimpact_zip = "${params.processed_annotations}/mitimpact.zip"
    mitotip_zip = "${params.processed_annotations}/mitotip.zip"
    napogee_zip = "${params.processed_annotations}/napogee.zip"

    // Outputs of the test run land here so they don't collide with prod paths.
    outdir = "test/_run_output"

    // Pin every monthly-rolling file to the `_test` suffix.
    fixed_month = "test"

    // Test cohort + per-cohort config.
    input_tsv = "test/fixtures/test.tsv"

    // The test cohort is too small to split.
    vcf_split_n = 0

    // Override the mostly-N stub fasta path. Default points at uncompressed ref.fa,
    // but we ship the bgzipped form because the masked stub compresses 250x.
    ref_genome = "${params.large_files}/ref.fa.gz"
}

// nextflow.config sets `outputDir = params.outdir` once during base config load,
// before this profile's params overrides take effect. Re-bind it here so the
// startup check in main.nf sees the test outdir.
outputDir = params.outdir

docker.enabled = true

// Tighter resources for CI - the test cohort is tiny and the runners are 2-core.
process {
    memory = 2.GB
    cpus = 1

    withName: 'AnnotatedVcfIntoMatrixTable' {
        memory = 4.GB
        cpus = 2
    }
}
